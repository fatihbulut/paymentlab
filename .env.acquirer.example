# Copy to ~/.env on the ACQUIRER server, then fill in values.
# Usage: docker compose -f ~/docker-compose.acquirer.yml up -d

# IP or hostname of the ISSUER server (TCP port 5001 must be reachable)
ISSUER_ADDR=<issuer-server-ip>:5001

# PostgreSQL password (used by acquirer's own DB and issuer DB connection)
POSTGRES_PASSWORD=changeme

# IP or hostname of the issuer server's PostgreSQL (for card CRUD only)
ISSUER_POSTGRES_HOST=<issuer-server-ip>

# HTTP port the acquirer web UI will listen on
ACQUIRER_PORT=8081

# Backpressure / timeouts (tune under k6)
CONCURRENT_LIMIT=200
MAX_QUEUE=0
QUEUE_WAIT_TIMEOUT_MS=0
ACQUIRER_REQUEST_TIMEOUT_SEC=2
SWITCH_TIMEOUT_MS=1600

# TCP connection pool towards issuer (acquirer->issuer)
ACQUIRER_TCP_POOL=100

# Docker image (pulled from ghcr.io by GitHub Actions)
ACQUIRER_IMAGE=ghcr.io/fatihbulut/iso-parser-service-acquirer:latest
