{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug ISO parser (main.go)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/parser",
            "cwd": "${workspaceFolder}",
            "env": {
                "GIN_MODE": "debug",
                "PORT": "8080"
            }
        },
        {
            "name": "Debug issuer (TCP)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/issuer",
            "cwd": "${workspaceFolder}",
            "env": {
              "ISSUER_ADDR": "localhost:5001"
            }
          }
    ]
}