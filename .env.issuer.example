# Copy to ~/.env on the ISSUER server, then fill in values.
# Usage: docker compose -f ~/docker-compose.issuer.yml up -d

# PostgreSQL password (also used by acquirer to connect remotely)
POSTGRES_PASSWORD=changeme

# Worker pool size for concurrent transaction processing (default: 1000)
# Increase for higher concurrency (e.g., 10000 for 100k concurrent)
ISSUER_WORKER_POOL=1000

# Docker image (pulled from ghcr.io by GitHub Actions)
ISSUER_IMAGE=ghcr.io/fatihbulut/iso-parser-service-issuer:latest
