# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable
ISSUER_DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# PostgreSQL Configuration
POSTGRES_DB=paymentlab
POSTGRES_USER=paymentlab
POSTGRES_PASSWORD=your_secure_password_here

# Database Pool Configuration
DB_POOL_MAX=120
DB_POOL_MIN=20
DB_SYNC_COMMIT=on
ISSUER_DB_POOL_MAX=5
ISSUER_DB_POOL_MIN=1

# Acquirer Configuration
ACQUIRER_PORT=8081
ACQUIRER_TCP_POOL=50
ACQUIRER_REQUEST_TIMEOUT_SEC=2
SWITCH_TIMEOUT_SEC=0.5
SWITCH_TIMEOUT_MS=500

# Concurrency Limiter Configuration
MAX_CONCURRENT=10
MAX_QUEUE=500
QUEUE_TIMEOUT_SEC=0.05

# Issuer Configuration
ISSUER_ADDR=localhost:5001
ISSUER_LISTEN=0.0.0.0:5001
ISSUER_WORKER_POOL=50
WORKER_ACQUIRE_TIMEOUT_SEC=2
REQUEST_TIMEOUT_SEC=3

# OpenTelemetry Configuration (Optional)
OTEL_SERVICE_NAME=acquirer
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_RESOURCE_ATTRIBUTES=service.namespace=paymentlab,deployment.environment=production
OTEL_TRACE_SAMPLE_RATE=0.01
