FROM golang:1.25-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/issuer ./cmd/issuer

FROM alpine:3.20

WORKDIR /app

COPY --from=builder /out/issuer /app/issuer
COPY web/spec.json /app/web/spec.json
COPY migrations /app/migrations

EXPOSE 5001

ENTRYPOINT ["/app/issuer"]
